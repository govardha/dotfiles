# bashrc.common — shared interactive shell config

parse_git_branch ()
{
    git branch 2> /dev/null | sed -e '/^[^*]/d' -e 's/* \(.*\)/(\1)/'
}

# Prompt with pyenv version
python_version() {
  if command -v pyenv &>/dev/null; then
    local ver
    ver=$(pyenv version-name 2>/dev/null)
    if [[ "${ver}" != "system" ]]; then
      echo -e " \033[0;36m(py:${ver})\033[00m"
    fi
  fi
}

export PS1='\[\033[01;32m\]\u@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]$([ -n "$AWS_PROFILE" ] && echo " \[\033[01;33m\](AWS:$AWS_PROFILE)\[\033[00m\]")\[\033[01;33m\]$(parse_git_branch)\[\033[00m\]\$ '

# Homebrew
if [[ -f "/home/linuxbrew/.linuxbrew/bin/brew" ]]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# Neovim
export EDITOR=nvim
alias vi='nvim'
alias vim='nvim'

# PATH
export PATH="${PATH}:${HOME}/.local/bin"

# Aliases
alias gfgp='git fetch && git pull'
alias awslogin='aws sso login --sso-session rinku --no-browser --use-device-code'

# Bash completions
if [[ -r "/home/linuxbrew/.linuxbrew/etc/profile.d/bash_completion.sh" ]]; then
  source "/home/linuxbrew/.linuxbrew/etc/profile.d/bash_completion.sh"
fi

# Pyenv
export PYENV_ROOT="${HOME}/.pyenv"
[[ -d "${PYENV_ROOT}/bin" ]] && export PATH="${PYENV_ROOT}/bin:${PATH}"
if command -v pyenv &>/dev/null; then
  eval "$(pyenv init - bash)"
fi

# NVM
export NVM_DIR="${HOME}/.nvm"
[[ -s "${NVM_DIR}/nvm.sh" ]] && source "${NVM_DIR}/nvm.sh"
[[ -s "${NVM_DIR}/bash_completion" ]] && source "${NVM_DIR}/bash_completion"

# AWS completer
if command -v aws_completer &>/dev/null; then
  complete -C "$(command -v aws_completer)" aws
fi

# Kiro CLI env (triggers co-author hook on git commits)
export KIRO_CLI=1

# Secrets (host-local, never committed)
[[ -f "${HOME}/.config/shell/secrets" ]] && source "${HOME}/.config/shell/secrets"
[[ -f "${HOME}/.config/shell/claude-providers.sh" ]] && source "${HOME}/.config/shell/claude-providers.sh"
