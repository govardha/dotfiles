{
  "name": "default",
  "description": "Broad infra/dev agent — sysops, k8s, AWS CDK, Java, shell/Python scripting",
  "tools": ["*"],
  "allowedTools": ["read", "glob", "grep"],
  "resources": [
    "file://.kiro/steering/**/*.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "~/.kiro/hooks/session-start.sh"
      }
    ],
    "userPromptSubmit": [
      {
        "command": "~/.kiro/hooks/prompt-guard.sh"
      }
    ],
    "preToolUse": [
      {
        "matcher": "execute_bash",
        "command": "~/.kiro/hooks/branch-guard.sh"
      },
      {
        "matcher": "fs_write",
        "command": "~/.kiro/hooks/branch-guard.sh"
      },
      {
        "matcher": "execute_bash",
        "command": "~/.kiro/hooks/bash-guard.sh"
      },
      {
        "matcher": "execute_bash",
        "command": "~/.kiro/hooks/pr-footer.sh"
      },
      {
        "matcher": "fs_write",
        "command": "~/.kiro/hooks/write-guard.sh"
      },
      {
        "matcher": "fs_write",
        "command": "~/.kiro/hooks/yaml-guard.sh"
      },
      {
        "matcher": "fs_write",
        "command": "~/.kiro/hooks/cdk-python-guard.sh"
      }
    ],
    "postToolUse": [
      {
        "command": "~/.kiro/hooks/audit.sh"
      }
    ]
  },
  "includeMcpJson": true
}
